# Allow DELETE and PUT — LiteSpeed blocks these by default
<Limit DELETE PUT PATCH>
  Order allow,deny
  Allow from all
</Limit>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Apache/CGI often drops Authorization before PHP — expose it as HTTP_AUTHORIZATION
  RewriteCond %{HTTP:Authorization} .
  RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  # Force https://www.kocourt.com — skip localhost / 127.0.0.1
  RewriteCond %{HTTP_HOST} !^localhost [NC]
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.kocourt.com%{REQUEST_URI} [L,R=301]

  # Route /api/* → backend (Vite dev-proxy equivalent for production)
  RewriteRule ^api/(.*)$ backend/index.php [L,QSA]

  # Pass real backend/* files/dirs through (assets, uploads etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^backend/ - [L]

  # Route /backend/* → backend/index.php (direct API calls)
  RewriteRule ^backend/(.*)$ backend/index.php [L,QSA]

  # All other requests → Vue SPA
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . index.html [L]
</IfModule>
