APP_DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=playbook
DB_USER=root
# Wrap passwords in double quotes if they contain special chars: $ , # ! @ & etc.
# DB_PASS="$PzFG70fUi,ThKfb"
DB_PASS=

# ── MSG91 OTP (SMS) ───────────────────────────────────────────────────────────
# Get from https://msg91.com → Dashboard → API → Auth Key
# Create an OTP template and paste the template ID below
# Leave blank to use demo mode (OTP = 1234)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# ── Deployment ────────────────────────────────────────────────────────────────
# Secret key for deploy.php (one-click deployer)
# Visit: https://kocourt.com/deploy.php?key=YOUR_DEPLOY_KEY
DEPLOY_KEY=change_this_to_a_random_secret

# GitHub repo (owner/repo) — used by deploy.php to pull latest code
GITHUB_REPO=Astra-Techno/playbook
GITHUB_BRANCH=main
# Only needed for private repos:
GITHUB_TOKEN=

# Secret key for migrate_web.php (standalone DB runner)
MIGRATE_KEY=change_this_to_a_random_secret

# ── Cashfree Payment Gateway ──────────────────────────────────────────────────
# Get keys from https://merchant.cashfree.com/merchants/pg  (API Keys section)
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
# 'sandbox' for testing, 'production' for live
CASHFREE_ENV=sandbox
