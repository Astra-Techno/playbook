APP_DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=playbook
DB_USER=root
# Wrap passwords in double quotes if they contain special chars: $ , # ! @ & etc.
# DB_PASS="$PzFG70fUi,ThKfb"
DB_PASS=

# ── MSG91 OTP (SMS) ───────────────────────────────────────────────────────────
# Get from https://msg91.com → Dashboard → API → Auth Key
# Create an OTP template and paste the template ID below
# Leave blank to use demo mode (OTP = 1234)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# ── Cashfree Payment Gateway ──────────────────────────────────────────────────
# Get keys from https://merchant.cashfree.com/merchants/pg  (API Keys section)
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
# 'sandbox' for testing, 'production' for live
CASHFREE_ENV=sandbox
